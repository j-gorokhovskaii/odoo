# sphinx build directories
_build/

# dotfiles
.*
!.gitignore
!.github
!.mailmap
# compiled python files
*.py[co]
__pycache__/
# setup.py egg_info
*.egg-info
# emacs backup files
*~
# hg stuff
*.orig
status
# odoo filestore
odoo/filestore
# maintenance migration scripts
odoo/addons/base/maintenance
# window installation config file
/odoo.conf

# generated for windows installer?
install/win32/*.bat
install/win32/meta.py

# needed only when building for win32
setup/win32/static/less/
setup/win32/static/wkhtmltopdf/
setup/win32/static/postgresql*.exe

# js tooling
node_modules
jsconfig.json
tsconfig.json
package-lock.json
package.json
.husky

# various virtualenv
/bin/
/build/
/dist/
/include/
/lib/
/man/
/share/
/src/

# Odoo runtime log (generated by start-odoo-hidden.vbs)
odoo.log

# ---------------------------------------------------------------------------
# Local / sensitive files — keep OUT of this public repo
# ---------------------------------------------------------------------------
# Database backups (real business data)
/database_backups/
# Local clone of Odoo's documentation site (not our work, large, own .git)
/documentation/
# Local brand/asset working folder
/my_contacts/
# Machine-specific operational docs (contain master password / DB names) + local reference docs
/RUNNING_ODOO.md
/INSTALLED_APPS_CHECKLIST.md
/ODOO_UPGRADE_PLAYBOOK.md
/KB_VS_DMS_AUDIT.md
/INDEX.md
# Local launcher scripts (machine paths; .bat references the master password)
/start-odoo.bat
/start-odoo-hidden.vbs
/stop-odoo.bat
# Local virtualenv (no leading dot, so not caught by the .* rule above)
/venv/

# Generated docs mirror for the odoo_documentation module (regenerate with
# addons/odoo_documentation/scripts/import_docs.py — don't version build output)
/addons/odoo_documentation/static/docs/
