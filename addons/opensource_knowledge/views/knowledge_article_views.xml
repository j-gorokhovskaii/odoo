<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Article Tree View -->
        <record id="knowledge_article_view_tree" model="ir.ui.view">
            <field name="name">knowledge.article.tree</field>
            <field name="model">knowledge.article</field>
            <field name="arch" type="xml">
                <tree string="Knowledge Articles" 
                      decoration-muted="stage == 'draft'" 
                      decoration-info="stage == 'review'" 
                      decoration-success="stage == 'published'"
                      decoration-warning="stage == 'archived'"
                      sample="1">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="author_id" widget="many2one_avatar_user"/>
                    <field name="category_id" optional="show"/>
                    <field name="tag_ids" widget="many2many_tags" optional="show"/>
                    <field name="article_type" optional="hide"/>
                    <field name="stage" widget="badge" 
                           decoration-muted="stage == 'draft'" 
                           decoration-info="stage == 'review'" 
                           decoration-success="stage == 'published'"
                           decoration-warning="stage == 'archived'"/>
                    <field name="visibility" optional="show"/>
                    <field name="view_count" optional="show"/>
                    <field name="word_count" optional="hide"/>
                    <field name="reading_time" optional="hide" string="Read Time (min)"/>
                    <field name="publish_date" optional="show"/>
                    <field name="last_review_date" optional="hide"/>
                    <field name="next_review_date" optional="hide"/>
                    <field name="has_children" invisible="1"/>
                    <field name="active" invisible="1"/>
                </tree>
            </field>
        </record>

        <!-- Article Form View -->
        <record id="knowledge_article_view_form" model="ir.ui.view">
            <field name="name">knowledge.article.form</field>
            <field name="model">knowledge.article</field>
            <field name="arch" type="xml">
                <form string="Knowledge Article">
                    <header>
                        <button name="action_publish" 
                                type="object" 
                                string="Publish" 
                                class="btn-primary"
                                attrs="{'invisible': [('stage', '!=', 'draft')]}"/>
                        <button name="action_submit_review" 
                                type="object" 
                                string="Submit for Review" 
                                attrs="{'invisible': [('stage', '!=', 'draft')]}"/>
                        <button name="action_archive" 
                                type="object" 
                                string="Archive" 
                                attrs="{'invisible': [('stage', '==', 'archived')]}"/>
                        <button name="action_duplicate" 
                                type="object" 
                                string="Duplicate"/>
                        <button name="action_create_template" 
                                type="object" 
                                string="Create Template"/>
                        <field name="stage" widget="statusbar" statusbar_visible="draft,review,published"/>
                    </header>
                    
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" type="object" name="action_view_versions" icon="fa-history">
                                <field string="Versions" name="version" widget="statinfo"/>
                            </button>
                            <button class="oe_stat_button" type="action" name="%(action_knowledge_article_child)d" icon="fa-sitemap" context="{'default_parent_id': active_id}" attrs="{'invisible': [('has_children', '=', False)]}">
                                <field string="Child Articles" name="child_ids" widget="statinfo"/>
                            </button>
                            <button class="oe_stat_button" type="object" name="increment_view_count" icon="fa-eye">
                                <field string="Views" name="view_count" widget="statinfo"/>
                            </button>
                        </div>

                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" attrs="{'invisible': [('active', '=', True)]}"/>
                        <widget name="web_ribbon" title="Template" bg_color="bg-info" attrs="{'invisible': [('is_template', '=', False)]}"/>

                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Article Title..." required="1"/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="author_id" widget="many2one_avatar_user" readonly="1"/>
                                <field name="category_id" options="{'no_create': True}"/>
                                <field name="parent_id" domain="[('id', '!=', id)]" options="{'no_create': True}"/>
                                <field name="template_id" options="{'no_create': True}" readonly="1"/>
                            </group>
                            <group>
                                <field name="article_type"/>
                                <field name="visibility"/>
                                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color', 'no_create_edit': True}"/>
                                <field name="is_template"/>
                            </group>
                        </group>

                        <group string="Content" col="1">
                            <field name="summary" placeholder="Brief summary of the article..."/>
                            <field name="body" widget="html" options="{'style-inline': true, 'collaborative': true}"/>
                        </group>

                        <group string="Statistics" col="4">
                            <field name="word_count" readonly="1"/>
                            <field name="reading_time" readonly="1"/>
                            <field name="version" readonly="1"/>
                            <field name="like_count" readonly="1"/>
                        </group>

                        <notebook>
                            <page string="Review &amp; Publishing">
                                <group>
                                    <group>
                                        <field name="reviewer_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                        <field name="publish_date" readonly="1"/>
                                        <field name="last_review_date"/>
                                    </group>
                                    <group>
                                        <field name="next_review_date"/>
                                        <field name="share_token" readonly="1" groups="opensource_knowledge.group_knowledge_manager"/>
                                        <field name="public_url" readonly="1" widget="url"/>
                                    </group>
                                </group>
                            </page>
                            
                            <page string="Permissions" groups="opensource_knowledge.group_knowledge_manager">
                                <field name="permission_ids" mode="tree,form">
                                    <tree string="Permissions" editable="bottom">
                                        <field name="user_id" attrs="{'readonly': [('group_id', '!=', False)]}"/>
                                        <field name="group_id" attrs="{'readonly': [('user_id', '!=', False)]}"/>
                                        <field name="permission"/>
                                        <field name="inherit_to_children"/>
                                        <field name="expiry_date"/>
                                    </tree>
                                </field>
                            </page>
                            
                            <page string="Child Articles" attrs="{'invisible': [('has_children', '=', False)]}">
                                <field name="child_ids" mode="tree,form">
                                    <tree string="Child Articles">
                                        <field name="sequence" widget="handle"/>
                                        <field name="name"/>
                                        <field name="author_id" widget="many2one_avatar_user"/>
                                        <field name="stage" widget="badge"/>
                                        <field name="view_count"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    
                    <div class="oe_chatter">
                        <field name="message_follower_ids" groups="base.group_user"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Article Kanban View -->
        <record id="knowledge_article_view_kanban" model="ir.ui.view">
            <field name="name">knowledge.article.kanban</field>
            <field name="model">knowledge.article</field>
            <field name="arch" type="xml">
                <kanban default_group_by="stage" class="o_kanban_small_column" sample="1">
                    <field name="id"/>
                    <field name="name"/>
                    <field name="author_id"/>
                    <field name="category_id"/>
                    <field name="tag_ids"/>
                    <field name="stage"/>
                    <field name="visibility"/>
                    <field name="view_count"/>
                    <field name="word_count"/>
                    <field name="reading_time"/>
                    <field name="publish_date"/>
                    <field name="activity_ids"/>
                    <field name="activity_state"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="o_dropdown_kanban dropdown">
                                    <a role="button" class="dropdown-toggle o-no-caret btn" data-toggle="dropdown" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                        <span class="fa fa-ellipsis-v"/>
                                    </a>
                                    <div class="dropdown-menu" role="menu">
                                        <a t-if="widget.editable" type="edit" class="dropdown-item">Edit</a>
                                        <a t-if="widget.deletable" type="delete" class="dropdown-item">Delete</a>
                                        <a name="action_duplicate" type="object" class="dropdown-item">Duplicate</a>
                                        <a name="action_create_template" type="object" class="dropdown-item">Create Template</a>
                                    </div>
                                </div>
                                
                                <div class="oe_kanban_content">
                                    <div class="o_kanban_record_top">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title"><field name="name"/></strong>
                                            <br/>
                                            <small class="o_kanban_record_subtitle text-muted">
                                                <field name="category_id"/>
                                                <t t-if="record.category_id.value and record.article_type.value"> • </t>
                                                <field name="article_type"/>
                                            </small>
                                        </div>
                                    </div>
                                    
                                    <div class="o_kanban_record_body">
                                        <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                        <div class="mt-1">
                                            <i class="fa fa-eye" title="Views"/> <field name="view_count"/>
                                            <t t-if="record.word_count.value">
                                                • <i class="fa fa-file-text-o" title="Words"/> <field name="word_count"/>
                                            </t>
                                            <t t-if="record.reading_time.value">
                                                • <i class="fa fa-clock-o" title="Reading time"/> <field name="reading_time"/>min
                                            </t>
                                        </div>
                                    </div>
                                    
                                    <div class="o_kanban_record_bottom">
                                        <div class="oe_kanban_bottom_left">
                                            <field name="activity_ids" widget="kanban_activity"/>
                                            <span t-if="record.visibility.value == 'public'" class="badge badge-success" title="Public">
                                                <i class="fa fa-globe" title="Public"/>
                                            </span>
                                            <span t-elif="record.visibility.value == 'portal'" class="badge badge-info" title="Portal">
                                                <i class="fa fa-users" title="Internal"/>
                                            </span>
                                            <span t-elif="record.visibility.value == 'private'" class="badge badge-warning" title="Private">
                                                <i class="fa fa-lock" title="Private"/>
                                            </span>
                                        </div>
                                        <div class="oe_kanban_bottom_right">
                                            <field name="author_id" widget="many2one_avatar_user"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Article Search View -->
        <record id="knowledge_article_view_search" model="ir.ui.view">
            <field name="name">knowledge.article.search</field>
            <field name="model">knowledge.article</field>
            <field name="arch" type="xml">
                <search string="Search Articles">
                    <field name="name" string="Title"/>
                    <field name="body" string="Content"/>
                    <field name="author_id"/>
                    <field name="category_id"/>
                    <field name="tag_ids"/>
                    <field name="summary"/>
                    
                    <filter string="My Articles" name="my_articles" domain="[('author_id', '=', uid)]"/>
                    <filter string="Draft" name="draft" domain="[('stage', '=', 'draft')]"/>
                    <filter string="Under Review" name="review" domain="[('stage', '=', 'review')]"/>
                    <filter string="Published" name="published" domain="[('stage', '=', 'published')]"/>
                    <filter string="Archived" name="archived" domain="[('stage', '=', 'archived')]"/>
                    
                    <separator/>
                    <filter string="Public" name="public" domain="[('visibility', '=', 'public')]"/>
                    <filter string="Internal" name="internal" domain="[('visibility', '=', 'internal')]"/>
                    <filter string="Private" name="private" domain="[('visibility', '=', 'private')]"/>
                    
                    <separator/>
                    <filter string="Templates" name="templates" domain="[('is_template', '=', True)]"/>
                    <filter string="Has Children" name="has_children" domain="[('has_children', '=', True)]"/>
                    <filter string="Popular" name="popular" domain="[('view_count', '>', 10)]"/>
                    
                    <separator/>
                    <filter string="Review Due" name="review_due" 
                            domain="[('next_review_date', '&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
                    <filter string="Recently Published" name="recent" 
                            domain="[('publish_date', '&gt;=', (context_today() - relativedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                    
                    <separator/>
                    <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                    
                    <group expand="0" string="Group By">
                        <filter string="Author" name="group_author" context="{'group_by': 'author_id'}"/>
                        <filter string="Category" name="group_category" context="{'group_by': 'category_id'}"/>
                        <filter string="Stage" name="group_stage" context="{'group_by': 'stage'}"/>
                        <filter string="Type" name="group_type" context="{'group_by': 'article_type'}"/>
                        <filter string="Visibility" name="group_visibility" context="{'group_by': 'visibility'}"/>
                        <filter string="Publication Date" name="group_publish_date" context="{'group_by': 'publish_date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Article Actions -->
        <record id="action_knowledge_article" model="ir.actions.act_window">
            <field name="name">Articles</field>
            <field name="res_model">knowledge.article</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="context">{
                'search_default_published': 1,
                'default_stage': 'draft',
                'default_author_id': uid,
            }</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first knowledge article!
                </p>
                <p>
                    Start building your knowledge base by creating articles that can be shared with your team.
                    Use templates to maintain consistency and organize content with categories and tags.
                </p>
            </field>
        </record>

        <record id="action_knowledge_article_child" model="ir.actions.act_window">
            <field name="name">Child Articles</field>
            <field name="res_model">knowledge.article</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('parent_id', '=', active_id)]</field>
            <field name="context">{
                'default_parent_id': active_id,
                'default_stage': 'draft',
                'default_author_id': uid,
            }</field>
        </record>

        <record id="action_knowledge_article_my" model="ir.actions.act_window">
            <field name="name">My Articles</field>
            <field name="res_model">knowledge.article</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="context">{
                'search_default_my_articles': 1,
                'default_author_id': uid,
            }</field>
        </record>

        <record id="action_knowledge_article_review" model="ir.actions.act_window">
            <field name="name">Articles to Review</field>
            <field name="res_model">knowledge.article</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('reviewer_ids', 'in', uid), ('stage', '=', 'review')]</field>
        </record>

    </data>
</odoo>