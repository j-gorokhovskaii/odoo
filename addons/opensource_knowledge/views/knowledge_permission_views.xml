<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Permission Tree View -->
        <record id="knowledge_permission_view_tree" model="ir.ui.view">
            <field name="name">knowledge.permission.tree</field>
            <field name="model">knowledge.permission</field>
            <field name="arch" type="xml">
                <tree string="Knowledge Permissions" 
                      decoration-muted="expiry_date and expiry_date &lt; context_today()"
                      sample="1">
                    <field name="article_id"/>
                    <field name="user_id"/>
                    <field name="group_id"/>
                    <field name="permission" widget="badge"/>
                    <field name="inherit_to_children"/>
                    <field name="expiry_date" optional="show"/>
                    <field name="create_uid" string="Granted by" optional="show"/>
                    <field name="create_date" optional="show"/>
                    <button name="action_revoke" type="object" string="Revoke" icon="fa-times" title="Revoke Permission"/>
                </tree>
            </field>
        </record>

        <!-- Permission Form View -->
        <record id="knowledge_permission_view_form" model="ir.ui.view">
            <field name="name">knowledge.permission.form</field>
            <field name="model">knowledge.permission</field>
            <field name="arch" type="xml">
                <form string="Knowledge Permission">
                    <header>
                        <button name="action_revoke" 
                                type="object" 
                                string="Revoke Permission" 
                                class="btn-danger"
                                confirm="Are you sure you want to revoke this permission?"/>
                        <button name="action_extend_expiry" 
                                type="object" 
                                string="Extend Expiry" 
                                attrs="{'invisible': [('expiry_date', '=', False)]}"/>
                    </header>
                    
                    <sheet>
                        <widget name="web_ribbon" title="Expired" bg_color="bg-danger" attrs="{'invisible': ['|', ('expiry_date', '=', False), ('expiry_date', '>', context_today())]}"/>

                        <group>
                            <group>
                                <field name="article_id" options="{'no_create': True}"/>
                                <field name="permission"/>
                                <field name="inherit_to_children"/>
                            </group>
                            <group>
                                <field name="user_id" attrs="{'readonly': [('group_id', '!=', False)], 'required': [('group_id', '=', False)]}"/>
                                <field name="group_id" attrs="{'readonly': [('user_id', '!=', False)], 'required': [('user_id', '=', False)]}"/>
                                <field name="expiry_date"/>
                            </group>
                        </group>

                        <group string="Sharing">
                            <field name="share_token" readonly="1"/>
                        </group>

                        <group string="Metadata">
                            <field name="create_uid" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Permission Search View -->
        <record id="knowledge_permission_view_search" model="ir.ui.view">
            <field name="name">knowledge.permission.search</field>
            <field name="model">knowledge.permission</field>
            <field name="arch" type="xml">
                <search string="Search Permissions">
                    <field name="article_id"/>
                    <field name="user_id"/>
                    <field name="group_id"/>
                    
                    <filter string="My Permissions" name="my_permissions" domain="[('user_id', '=', uid)]"/>
                    <filter string="Read" name="read" domain="[('permission', '=', 'read')]"/>
                    <filter string="Write" name="write" domain="[('permission', '=', 'write')]"/>
                    <filter string="Comment" name="comment" domain="[('permission', '=', 'comment')]"/>
                    <filter string="Manage" name="manage" domain="[('permission', '=', 'manage')]"/>
                    
                    <separator/>
                    <filter string="Expired" name="expired" domain="[('expiry_date', '&lt;', context_today())]"/>
                    <filter string="Expiring Soon" name="expiring_soon" domain="[('expiry_date', '&lt;=', (context_today() + relativedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                    <filter string="No Expiry" name="no_expiry" domain="[('expiry_date', '=', False)]"/>
                    
                    <group expand="0" string="Group By">
                        <filter string="Article" name="group_article" context="{'group_by': 'article_id'}"/>
                        <filter string="User" name="group_user" context="{'group_by': 'user_id'}"/>
                        <filter string="Group" name="group_group" context="{'group_by': 'group_id'}"/>
                        <filter string="Permission" name="group_permission" context="{'group_by': 'permission'}"/>
                        <filter string="Granted Date" name="group_create_date" context="{'group_by': 'create_date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Share Tree View -->
        <record id="knowledge_share_view_tree" model="ir.ui.view">
            <field name="name">knowledge.share.tree</field>
            <field name="model">knowledge.share</field>
            <field name="arch" type="xml">
                <tree string="Knowledge Shares" 
                      decoration-muted="not active"
                      decoration-danger="expiry_date and expiry_date &lt; context_today()"
                      sample="1">
                    <field name="article_id"/>
                    <field name="share_type" widget="badge"/>
                    <field name="view_count"/>
                    <field name="max_views" optional="show"/>
                    <field name="expiry_date" optional="show"/>
                    <field name="allow_download" optional="show"/>
                    <field name="allow_print" optional="show"/>
                    <field name="create_uid" string="Shared by" optional="show"/>
                    <field name="create_date" optional="show"/>
                    <field name="active" invisible="1"/>
                    <button name="action_copy_link" type="object" string="Copy Link" icon="fa-copy" title="Copy Share Link"/>
                    <button name="action_disable" type="object" string="Disable" icon="fa-ban" title="Disable Share" attrs="{'invisible': [('active', '=', False)]}"/>
                </tree>
            </field>
        </record>

        <!-- Share Form View -->
        <record id="knowledge_share_view_form" model="ir.ui.view">
            <field name="name">knowledge.share.form</field>
            <field name="model">knowledge.share</field>
            <field name="arch" type="xml">
                <form string="Knowledge Share">
                    <header>
                        <button name="action_copy_link" 
                                type="object" 
                                string="Copy Link" 
                                class="btn-primary"/>
                        <button name="action_disable" 
                                type="object" 
                                string="Disable Share" 
                                class="btn-danger"
                                attrs="{'invisible': [('active', '=', False)]}"
                                confirm="Are you sure you want to disable this share?"/>
                    </header>
                    
                    <sheet>
                        <widget name="web_ribbon" title="Disabled" bg_color="bg-danger" attrs="{'invisible': [('active', '=', True)]}"/>
                        <widget name="web_ribbon" title="Expired" bg_color="bg-warning" attrs="{'invisible': ['|', ('expiry_date', '=', False), ('expiry_date', '>', context_today())]}"/>

                        <group>
                            <group>
                                <field name="article_id" options="{'no_create': True}"/>
                                <field name="share_type"/>
                                <field name="password" attrs="{'invisible': [('share_type', '!=', 'protected')], 'required': [('share_type', '=', 'protected')]}"/>
                            </group>
                            <group>
                                <field name="expiry_date"/>
                                <field name="max_views"/>
                                <field name="view_count" readonly="1"/>
                                <field name="active"/>
                            </group>
                        </group>

                        <group string="Permissions">
                            <field name="allow_download"/>
                            <field name="allow_print"/>
                            <field name="track_views"/>
                        </group>

                        <group string="Share Link">
                            <field name="share_token" readonly="1"/>
                            <field name="get_share_url" string="Full URL" readonly="1" widget="url"/>
                        </group>

                        <group string="Metadata">
                            <field name="create_uid" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Share Search View -->
        <record id="knowledge_share_view_search" model="ir.ui.view">
            <field name="name">knowledge.share.search</field>
            <field name="model">knowledge.share</field>
            <field name="arch" type="xml">
                <search string="Search Shares">
                    <field name="article_id"/>
                    <field name="share_type"/>
                    
                    <filter string="My Shares" name="my_shares" domain="[('create_uid', '=', uid)]"/>
                    <filter string="Public" name="public" domain="[('share_type', '=', 'public')]"/>
                    <filter string="Protected" name="protected" domain="[('share_type', '=', 'protected')]"/>
                    <filter string="Temporary" name="temporary" domain="[('share_type', '=', 'temporary')]"/>
                    
                    <separator/>
                    <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Expired" name="expired" domain="[('expiry_date', '&lt;', context_today())]"/>
                    <filter string="View Limit Reached" name="limit_reached" domain="[('max_views', '>', 0), ('view_count', '>=', 'max_views')]"/>
                    
                    <group expand="0" string="Group By">
                        <filter string="Article" name="group_article" context="{'group_by': 'article_id'}"/>
                        <filter string="Share Type" name="group_share_type" context="{'group_by': 'share_type'}"/>
                        <filter string="Shared By" name="group_create_uid" context="{'group_by': 'create_uid'}"/>
                        <filter string="Creation Date" name="group_create_date" context="{'group_by': 'create_date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Permission Actions -->
        <record id="action_knowledge_permission" model="ir.actions.act_window">
            <field name="name">Article Permissions</field>
            <field name="res_model">knowledge.permission</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No permissions configured yet!
                </p>
                <p>
                    Permissions allow you to grant specific users or groups access to articles with different levels of access.
                </p>
            </field>
        </record>

        <record id="action_knowledge_share" model="ir.actions.act_window">
            <field name="name">Article Shares</field>
            <field name="res_model">knowledge.share</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No shares created yet!
                </p>
                <p>
                    Share links allow you to provide external access to articles with customizable permissions and expiration dates.
                </p>
            </field>
        </record>

    </data>
</odoo>