<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Opens the live, version-matched official Odoo documentation in a new browser tab.
         (No local copy is stored; always current.) -->
    <record id="action_documentation_url" model="ir.actions.act_url">
        <field name="name">Odoo Documentation</field>
        <field name="url">https://www.odoo.com/documentation/18.0/</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_documentation_root"
              name="Documentation"
              web_icon="odoo_documentation,static/description/icon.png"
              action="action_documentation_url"
              sequence="100"/>
</odoo>
