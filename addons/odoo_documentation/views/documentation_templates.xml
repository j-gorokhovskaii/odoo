<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="documentation_index" name="Documentation Index">
        <t t-call="web.layout">
            <t t-set="title">Odoo Documentation</t>
            <div class="container-fluid mt-3">
                <div class="row">
                    <div class="col-12">
                        <h1 class="text-center mb-4">Odoo 18.0 Documentation</h1>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-3">
                        <div class="card mb-3">
                            <div class="card-header bg-primary text-white">
                                <h4 class="mb-0">Navigation</h4>
                            </div>
                            <div class="card-body">
                                <ul class="list-unstyled">
                                    <li><a href="#" onclick="loadDoc('index.html')">Home</a></li>
                                    <li class="mt-2"><strong>Applications</strong></li>
                                    <li><a href="#" onclick="loadDoc('applications/index.html')">Overview</a></li>
                                    <li class="mt-2"><strong>Administration</strong></li>
                                    <li><a href="#" onclick="loadDoc('administration/index.html')">Overview</a></li>
                                    <li class="mt-2"><strong>Developer</strong></li>
                                    <li><a href="#" onclick="loadDoc('developer/index.html')">Overview</a></li>
                                    <li class="mt-2"><strong>Contributing</strong></li>
                                    <li><a href="#" onclick="loadDoc('contributing/index.html')">Overview</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-9">
                        <div class="card">
                            <div class="card-body">
                                <iframe id="doc-frame" src="/odoo_documentation/static/docs/index.html" 
                                        style="width: 100%; height: 800px; border: none;"></iframe>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <script>
                function loadDoc(path) {
                    document.getElementById('doc-frame').src = '/odoo_documentation/static/docs/' + path;
                }
            </script>
        </t>
    </template>
    
    <template id="documentation_viewer" name="Documentation Viewer">
        <t t-call="web.layout">
            <t t-set="title"><t t-esc="doc_title"/> - Odoo Documentation</t>
            <div class="container-fluid mt-3">
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h3><t t-esc="doc_title"/></h3>
                            </div>
                            <div class="card-body documentation-content">
                                <t t-raw="doc_content"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>