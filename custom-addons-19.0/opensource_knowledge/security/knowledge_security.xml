<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Categories -->
        <record id="module_category_knowledge" model="ir.module.category">
            <field name="name">Knowledge Management</field>
            <field name="description">Knowledge Management System</field>
            <field name="sequence">30</field>
        </record>

        <!-- Privilege (19.0: groups link to a res.groups.privilege, which holds the category) -->
        <record id="res_groups_privilege_knowledge" model="res.groups.privilege">
            <field name="name">Knowledge Management</field>
            <field name="sequence">30</field>
            <field name="category_id" ref="module_category_knowledge"/>
        </record>

        <!-- Groups -->
        <record id="group_knowledge_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="res_groups_privilege_knowledge"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Basic knowledge management access - can read and create articles</field>
        </record>

        <record id="group_knowledge_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_knowledge"/>
            <field name="implied_ids" eval="[(4, ref('group_knowledge_user'))]"/>
            <field name="comment">Knowledge management - can manage categories, templates, and review articles</field>
        </record>

        <record id="group_knowledge_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="privilege_id" ref="res_groups_privilege_knowledge"/>
            <field name="implied_ids" eval="[(4, ref('group_knowledge_manager'))]"/>
            <field name="comment">Knowledge administration - full access to all features</field>
        </record>

        <!-- Record Rules for Articles -->
        <record id="knowledge_article_rule_user" model="ir.rule">
            <field name="name">Article User Read Access</field>
            <field name="model_id" ref="model_knowledge_article"/>
            <field name="groups" eval="[(4, ref('group_knowledge_user'))]"/>
            <field name="domain_force">[
                '|', '|', '|', '|',
                ('author_id', '=', user.id),
                ('visibility', '=', 'public'),
                ('visibility', '=', 'internal'),
                ('permission_ids.user_id', '=', user.id),
                ('permission_ids.group_id', 'in', user.group_ids.ids)
            ]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="knowledge_article_rule_author" model="ir.rule">
            <field name="name">Article Author Full Access</field>
            <field name="model_id" ref="model_knowledge_article"/>
            <field name="groups" eval="[(4, ref('group_knowledge_user'))]"/>
            <field name="domain_force">[('author_id', '=', user.id)]</field>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="knowledge_article_rule_manager" model="ir.rule">
            <field name="name">Article Manager Access</field>
            <field name="model_id" ref="model_knowledge_article"/>
            <field name="groups" eval="[(4, ref('group_knowledge_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Record Rules for Categories -->
        <record id="knowledge_category_rule_user" model="ir.rule">
            <field name="name">Category User Access</field>
            <field name="model_id" ref="model_knowledge_category"/>
            <field name="groups" eval="[(4, ref('group_knowledge_user'))]"/>
            <field name="domain_force">[
                '|', '|', '|', '|',
                ('visibility', '=', 'public'),
                ('visibility', '=', 'internal'),
                ('manager_id', '=', user.id),
                ('permission_ids.user_id', '=', user.id),
                ('permission_ids.group_id', 'in', user.group_ids.ids)
            ]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="knowledge_category_rule_manager" model="ir.rule">
            <field name="name">Category Manager Access</field>
            <field name="model_id" ref="model_knowledge_category"/>
            <field name="groups" eval="[(4, ref('group_knowledge_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Record Rules for Templates -->
        <record id="knowledge_template_rule_user" model="ir.rule">
            <field name="name">Template User Access</field>
            <field name="model_id" ref="model_knowledge_template"/>
            <field name="groups" eval="[(4, ref('group_knowledge_user'))]"/>
            <field name="domain_force">[
                '|', '|', '|',
                ('is_public', '=', True),
                ('author_id', '=', user.id),
                ('user_ids', 'in', [user.id]),
                ('group_ids', 'in', user.group_ids.ids)
            ]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="knowledge_template_rule_author" model="ir.rule">
            <field name="name">Template Author Access</field>
            <field name="model_id" ref="model_knowledge_template"/>
            <field name="groups" eval="[(4, ref('group_knowledge_user'))]"/>
            <field name="domain_force">[('author_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="knowledge_template_rule_manager" model="ir.rule">
            <field name="name">Template Manager Access</field>
            <field name="model_id" ref="model_knowledge_template"/>
            <field name="groups" eval="[(4, ref('group_knowledge_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Record Rules for Tags -->
        <record id="knowledge_tag_rule_user" model="ir.rule">
            <field name="name">Tag User Access</field>
            <field name="model_id" ref="model_knowledge_tag"/>
            <field name="groups" eval="[(4, ref('group_knowledge_user'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="knowledge_tag_rule_manager" model="ir.rule">
            <field name="name">Tag Manager Access</field>
            <field name="model_id" ref="model_knowledge_tag"/>
            <field name="groups" eval="[(4, ref('group_knowledge_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Record Rules for Permissions -->
        <record id="knowledge_permission_rule_user" model="ir.rule">
            <field name="name">Permission User Access</field>
            <field name="model_id" ref="model_knowledge_permission"/>
            <field name="groups" eval="[(4, ref('group_knowledge_user'))]"/>
            <field name="domain_force">[
                '|', '|',
                ('article_id.author_id', '=', user.id),
                ('user_id', '=', user.id),
                ('group_id', 'in', user.group_ids.ids)
            ]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="knowledge_permission_rule_manager" model="ir.rule">
            <field name="name">Permission Manager Access</field>
            <field name="model_id" ref="model_knowledge_permission"/>
            <field name="groups" eval="[(4, ref('group_knowledge_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Portal Access Rules -->
        <record id="knowledge_article_portal_rule" model="ir.rule">
            <field name="name">Article Portal Access</field>
            <field name="model_id" ref="model_knowledge_article"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">[
                '|', '|',
                ('visibility', '=', 'public'),
                ('visibility', '=', 'portal'),
                ('permission_ids.user_id', '=', user.id)
            ]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Public Access Rules -->
        <record id="knowledge_article_public_rule" model="ir.rule">
            <field name="name">Article Public Access</field>
            <field name="model_id" ref="model_knowledge_article"/>
            <field name="groups" eval="[(4, ref('base.group_public'))]"/>
            <field name="domain_force">[('visibility', '=', 'public')]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>