<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Template Tree View -->
        <record id="knowledge_template_view_tree" model="ir.ui.view">
            <field name="name">knowledge.template.tree</field>
            <field name="model">knowledge.template</field>
            <field name="arch" type="xml">
                <list string="Knowledge Templates" 
                      decoration-muted="not active"
                      sample="1">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="author_id" widget="many2one_avatar_user"/>
                    <field name="template_type" optional="show"/>
                    <field name="article_type" optional="show"/>
                    <field name="category_id" optional="show"/>
                    <field name="usage_count" optional="show"/>
                    <!-- <field name="article_count" optional="show"/> -->
                    <!-- <field name="last_used_date" optional="show"/> -->
                    <field name="is_public" optional="show"/>
                    <field name="active" invisible="1"/>
                </list>
            </field>
        </record>

        <!-- Template Form View -->
        <record id="knowledge_template_view_form" model="ir.ui.view">
            <field name="name">knowledge.template.form</field>
            <field name="model">knowledge.template</field>
            <field name="arch" type="xml">
                <form string="Knowledge Template">
                    <header>
                        <button name="action_create_article" 
                                type="object" 
                                string="Create Article" 
                                class="btn-primary"/>
                        <button name="action_preview" 
                                type="object" 
                                string="Preview"/>
                        <button name="action_duplicate" 
                                type="object" 
                                string="Duplicate"/>
                    </header>
                    
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" type="object" name="action_view_articles" icon="fa-file-text-o">
                                <!-- <field string="Articles Created" name="article_count" widget="statinfo"/> -->
                            </button>
                            <button class="oe_stat_button" type="object" name="action_create_article" icon="fa-plus">
                                <field string="Usage Count" name="usage_count" widget="statinfo"/>
                            </button>
                        </div>

                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>

                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Template Name..." required="1"/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="author_id" widget="many2one_avatar_user" readonly="1"/>
                                <field name="template_type"/>
                                <field name="article_type"/>
                                <field name="category_id" options="{'no_create': True}"/>
                            </group>
                            <group>
                                <field name="visibility"/>
                                <field name="is_public"/>
                                <field name="active"/>
                                <!-- <field name="last_used_date" readonly="1"/> -->
                            </group>
                        </group>

                        <group string="Description">
                            <field name="description" nolabel="1" placeholder="Describe what this template is used for..."/>
                        </group>

                        <group string="Default Tags">
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color', 'no_create_edit': True}" nolabel="1"/>
                        </group>

                        <notebook>
                            <page string="Template Content">
                                <field name="body" widget="html" options="{'style-inline': true}"/>
                            </page>
                            
                            <page string="Form Fields" invisible="template_type != 'form'">
                                <field name="field_ids" mode="tree,form">
                                    <list string="Fields" editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="name"/>
                                        <field name="label"/>
                                        <field name="field_type"/>
                                        <field name="required"/>
                                        <field name="default_value"/>
                                        <field name="placeholder"/>
                                    </list>
                                    <form string="Template Field">
                                        <group>
                                            <group>
                                                <field name="name"/>
                                                <field name="label"/>
                                                <field name="field_type"/>
                                                <field name="required"/>
                                            </group>
                                            <group>
                                                <field name="sequence"/>
                                                <field name="default_value"/>
                                                <field name="placeholder"/>
                                            </group>
                                        </group>
                                        <group string="Help Text">
                                            <field name="help_text" nolabel="1"/>
                                        </group>
                                        <group string="Selection Options" invisible="field_type != 'selection'">
                                            <field name="selection_options" nolabel="1" placeholder="Option 1&#10;Option 2&#10;Option 3"/>
                                        </group>
                                    </form>
                                </field>
                            </page>
                            
                            <page string="Access Control" invisible="is_public">
                                <group>
                                    <group string="Authorized Users">
                                        <field name="user_ids" widget="many2many_tags" nolabel="1"/>
                                    </group>
                                    <group string="Authorized Groups">
                                        <field name="group_ids" widget="many2many_tags" nolabel="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    
                    <div class="oe_chatter">
                        <field name="message_follower_ids" groups="base.group_user"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Template Kanban View -->
        <record id="knowledge_template_view_kanban" model="ir.ui.view">
            <field name="name">knowledge.template.kanban</field>
            <field name="model">knowledge.template</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" sample="1">
                    <field name="id"/>
                    <field name="name"/>
                    <field name="author_id"/>
                    <field name="template_type"/>
                    <field name="article_type"/>
                    <field name="category_id"/>
                    <field name="usage_count"/>
                    <!-- <field name="article_count"/> -->
                    <field name="is_public"/>
                    <field name="active"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="o_dropdown_kanban dropdown">
                                    <a role="button" class="dropdown-toggle o-no-caret btn" data-toggle="dropdown" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                        <span class="fa fa-ellipsis-v"/>
                                    </a>
                                    <div class="dropdown-menu" role="menu">
                                        <a t-if="widget.editable" type="edit" class="dropdown-item">Edit</a>
                                        <a t-if="widget.deletable" type="delete" class="dropdown-item">Delete</a>
                                        <a name="action_create_article" type="object" class="dropdown-item">Create Article</a>
                                        <a name="action_preview" type="object" class="dropdown-item">Preview</a>
                                        <a name="action_duplicate" type="object" class="dropdown-item">Duplicate</a>
                                    </div>
                                </div>
                                
                                <div class="oe_kanban_content">
                                    <div class="o_kanban_record_top">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title">
                                                <i t-if="record.template_type.value == 'form'" class="fa fa-list-alt" title="Form Template"/>
                                                <i t-elif="record.template_type.value == 'checklist'" class="fa fa-check-square-o" title="Checklist Template"/>
                                                <i t-elif="record.template_type.value == 'workflow'" class="fa fa-sitemap" title="Workflow Template"/>
                                                <i t-else="" class="fa fa-file-text-o" title="Standard Template"/>
                                                <field name="name"/>
                                            </strong>
                                            <small class="o_kanban_record_subtitle text-muted">
                                                <field name="category_id"/>
                                                <t t-if="record.category_id.value and record.article_type.value"> • </t>
                                                <field name="article_type"/>
                                            </small>
                                        </div>
                                    </div>
                                    
                                    <div class="o_kanban_record_body">
                                        <div class="row">
                                            <div class="col-6">
                                                <strong><field name="usage_count"/></strong>
                                                <br/>
                                                <small class="text-muted">Times Used</small>
                                            </div>
                                            <div class="col-6">
                                                <strong><!-- <field name="article_count"/> --></strong>
                                                <br/>
                                                <small class="text-muted">Articles Created</small>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="o_kanban_record_bottom">
                                        <div class="oe_kanban_bottom_left">
                                            <span t-if="record.is_public.value" class="badge badge-success" title="Public Template">
                                                <i class="fa fa-globe"/>
                                            </span>
                                            <span t-else="" class="badge badge-warning" title="Private Template">
                                                <i class="fa fa-lock"/>
                                            </span>
                                        </div>
                                        <div class="oe_kanban_bottom_right">
                                            <field name="author_id" widget="many2one_avatar_user"/>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="oe_kanban_footer">
                                    <button name="action_create_article" type="object" class="btn btn-primary btn-sm">
                                        <i class="fa fa-plus"/> Create Article
                                    </button>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Template Search View -->
        <record id="knowledge_template_view_search" model="ir.ui.view">
            <field name="name">knowledge.template.search</field>
            <field name="model">knowledge.template</field>
            <field name="arch" type="xml">
                <search string="Search Templates">
                    <field name="name"/>
                    <field name="author_id"/>
                    <field name="category_id"/>
                    <field name="description"/>
                    
                    <filter string="My Templates" name="my_templates" domain="[('author_id', '=', uid)]"/>
                    <filter string="Public" name="public" domain="[('is_public', '=', True)]"/>
                    <filter string="Private" name="private" domain="[('is_public', '=', False)]"/>
                    
                    <separator/>
                    <filter string="Standard" name="standard" domain="[('template_type', '=', 'standard')]"/>
                    <filter string="Form" name="form" domain="[('template_type', '=', 'form')]"/>
                    <filter string="Checklist" name="checklist" domain="[('template_type', '=', 'checklist')]"/>
                    <filter string="Workflow" name="workflow" domain="[('template_type', '=', 'workflow')]"/>
                    
                    <separator/>
                    <filter string="Popular" name="popular" domain="[('usage_count', '>', 5)]"/>
                    <filter string="Recently Used" name="recent" domain="[]"/>
                    <filter string="Unused" name="unused" domain="[('usage_count', '=', 0)]"/>
                    
                    <separator/>
                    <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                    
                    <separator/>
                        <filter string="Author" name="group_author" context="{'group_by': 'author_id'}"/>
                        <filter string="Category" name="group_category" context="{'group_by': 'category_id'}"/>
                        <filter string="Template Type" name="group_template_type" context="{'group_by': 'template_type'}"/>
                        <filter string="Article Type" name="group_article_type" context="{'group_by': 'article_type'}"/>
                        <filter string="Visibility" name="group_visibility" context="{'group_by': 'visibility'}"/>
                </search>
            </field>
        </record>

        <!-- Template Actions -->
        <record id="action_knowledge_template" model="ir.actions.act_window">
            <field name="name">Templates</field>
            <field name="res_model">knowledge.template</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="context">{
                'search_default_public': 1,
                'default_author_id': uid,
                'default_is_public': True,
            }</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first knowledge template!
                </p>
                <p>
                    Templates help maintain consistency across your knowledge base. Create templates for common 
                    article types like procedures, FAQs, or documentation formats.
                </p>
            </field>
        </record>

        <record id="action_knowledge_template_my" model="ir.actions.act_window">
            <field name="name">My Templates</field>
            <field name="res_model">knowledge.template</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="context">{
                'search_default_my_templates': 1,
                'default_author_id': uid,
            }</field>
        </record>

    </data>
</odoo>