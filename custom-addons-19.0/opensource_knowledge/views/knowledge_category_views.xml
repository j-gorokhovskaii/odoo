<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Category Tree View -->
        <record id="knowledge_category_view_tree" model="ir.ui.view">
            <field name="name">knowledge.category.tree</field>
            <field name="model">knowledge.category</field>
            <field name="arch" type="xml">
                <list string="Knowledge Categories" 
                      decoration-muted="not active"
                      sample="1">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="parent_id" optional="show"/>
                    <field name="manager_id" widget="many2one_avatar_user" optional="show"/>
                    <field name="visibility" optional="show"/>
                    <field name="direct_article_count" string="Direct Articles"/>
                    <field name="article_count" string="Total Articles"/>
                    <field name="level" optional="hide"/>
                    <field name="color" widget="color_picker" optional="hide"/>
                    <field name="active" invisible="1"/>
                </list>
            </field>
        </record>

        <!-- Category Form View -->
        <record id="knowledge_category_view_form" model="ir.ui.view">
            <field name="name">knowledge.category.form</field>
            <field name="model">knowledge.category</field>
            <field name="arch" type="xml">
                <form string="Knowledge Category">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" type="object" name="action_view_articles" icon="fa-file-text-o">
                                <field string="Total Articles" name="article_count" widget="statinfo"/>
                            </button>
                            <button class="oe_stat_button" type="object" name="action_create_article" icon="fa-plus">
                                <field string="Direct Articles" name="direct_article_count" widget="statinfo"/>
                            </button>
                        </div>

                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>

                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Category Name..." required="1"/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="parent_id" domain="[('id', '!=', id)]" options="{'no_create': True}"/>
                                <field name="manager_id" widget="many2one_avatar_user" options="{'no_create': True}"/>
                                <field name="sequence"/>
                            </group>
                            <group>
                                <field name="visibility"/>
                                <field name="color" widget="color_picker"/>
                                <field name="active"/>
                            </group>
                        </group>

                        <group string="Description">
                            <field name="description" nolabel="1" placeholder="Describe what this category contains..."/>
                        </group>

                        <notebook>
                            <page string="Articles">
                                <field name="article_ids" mode="tree,form">
                                    <list string="Articles" create="false">
                                        <field name="name"/>
                                        <field name="author_id" widget="many2one_avatar_user"/>
                                        <field name="stage" widget="badge"/>
                                        <field name="view_count"/>
                                        <field name="publish_date"/>
                                    </list>
                                </field>
                            </page>
                            
                            <page string="Subcategories" invisible="not has_children">
                                <field name="child_ids" mode="tree,form">
                                    <list string="Subcategories">
                                        <field name="sequence" widget="handle"/>
                                        <field name="name"/>
                                        <field name="manager_id" widget="many2one_avatar_user"/>
                                        <field name="visibility"/>
                                        <field name="article_count"/>
                                        <field name="active"/>
                                    </list>
                                </field>
                            </page>
                            
                            <page string="Permissions" groups="opensource_knowledge.group_knowledge_manager">
                                <field name="permission_ids" mode="tree,form">
                                    <list string="Permissions" editable="bottom">
                                        <field name="user_id" readonly="group_id"/>
                                        <field name="group_id" readonly="user_id"/>
                                        <field name="permission"/>
                                        <field name="inherit_to_children"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    
                    <div class="oe_chatter">
                        <field name="message_follower_ids" groups="base.group_user"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Category Kanban View -->
        <record id="knowledge_category_view_kanban" model="ir.ui.view">
            <field name="name">knowledge.category.kanban</field>
            <field name="model">knowledge.category</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" sample="1">
                    <field name="id"/>
                    <field name="name"/>
                    <field name="parent_id"/>
                    <field name="manager_id"/>
                    <field name="visibility"/>
                    <field name="article_count"/>
                    <field name="direct_article_count"/>
                    <field name="color"/>
                    <field name="active"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click" t-attf-style="border-left: 3px solid {{ kanban_color(record.color.raw_value) }}">
                                <div class="o_dropdown_kanban dropdown">
                                    <a role="button" class="dropdown-toggle o-no-caret btn" data-toggle="dropdown" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                        <span class="fa fa-ellipsis-v"/>
                                    </a>
                                    <div class="dropdown-menu" role="menu">
                                        <a t-if="widget.editable" type="edit" class="dropdown-item">Edit</a>
                                        <a t-if="widget.deletable" type="delete" class="dropdown-item">Delete</a>
                                        <a name="action_create_article" type="object" class="dropdown-item">Create Article</a>
                                        <a name="action_view_articles" type="object" class="dropdown-item">View Articles</a>
                                    </div>
                                </div>
                                
                                <div class="oe_kanban_content">
                                    <div class="o_kanban_record_top">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title">
                                                <span t-if="record.color.raw_value" t-attf-style="color: {{ kanban_color(record.color.raw_value) }}">
                                                    <i class="fa fa-circle"/>
                                                </span>
                                                <field name="name"/>
                                            </strong>
                                            <small class="o_kanban_record_subtitle text-muted" t-if="record.parent_id.value">
                                                <field name="parent_id"/>
                                            </small>
                                        </div>
                                    </div>
                                    
                                    <div class="o_kanban_record_body">
                                        <div class="row">
                                            <div class="col-6">
                                                <strong><field name="direct_article_count"/></strong>
                                                <br/>
                                                <small class="text-muted">Direct Articles</small>
                                            </div>
                                            <div class="col-6">
                                                <strong><field name="article_count"/></strong>
                                                <br/>
                                                <small class="text-muted">Total Articles</small>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="o_kanban_record_bottom">
                                        <div class="oe_kanban_bottom_left">
                                            <span t-if="record.visibility.value == 'public'" class="badge badge-success" title="Public">
                                                <i class="fa fa-globe"/>
                                            </span>
                                            <span t-elif="record.visibility.value == 'portal'" class="badge badge-info" title="Portal">
                                                <i class="fa fa-users"/>
                                            </span>
                                            <span t-elif="record.visibility.value == 'private'" class="badge badge-warning" title="Private">
                                                <i class="fa fa-lock"/>
                                            </span>
                                        </div>
                                        <div class="oe_kanban_bottom_right">
                                            <field name="manager_id" widget="many2one_avatar_user"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Category Search View -->
        <record id="knowledge_category_view_search" model="ir.ui.view">
            <field name="name">knowledge.category.search</field>
            <field name="model">knowledge.category</field>
            <field name="arch" type="xml">
                <search string="Search Categories">
                    <field name="name"/>
                    <field name="parent_id"/>
                    <field name="manager_id"/>
                    <field name="description"/>
                    
                    <filter string="Root Categories" name="root" domain="[('parent_id', '=', False)]"/>
                    <filter string="My Categories" name="my_categories" domain="[('manager_id', '=', uid)]"/>
                    <filter string="Public" name="public" domain="[('visibility', '=', 'public')]"/>
                    <filter string="Internal" name="internal" domain="[('visibility', '=', 'internal')]"/>
                    <filter string="Private" name="private" domain="[('visibility', '=', 'private')]"/>
                    
                    <separator/>
                    <filter string="With Articles" name="with_articles" domain="[('direct_article_count', '>', 0)]"/>
                    <filter string="Empty" name="empty" domain="[('direct_article_count', '=', 0)]"/>
                    
                    <separator/>
                    <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                    
                    <separator/>
                        <filter string="Parent Category" name="group_parent" context="{'group_by': 'parent_id'}"/>
                        <filter string="Manager" name="group_manager" context="{'group_by': 'manager_id'}"/>
                        <filter string="Visibility" name="group_visibility" context="{'group_by': 'visibility'}"/>
                        <filter string="Level" name="group_level" context="{'group_by': 'level'}"/>
                </search>
            </field>
        </record>

        <!-- Category Actions -->
        <record id="action_knowledge_category" model="ir.actions.act_window">
            <field name="name">Categories</field>
            <field name="res_model">knowledge.category</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first knowledge category!
                </p>
                <p>
                    Organize your knowledge base with categories that help users find relevant content quickly.
                    You can create hierarchical categories and set different visibility levels.
                </p>
            </field>
        </record>

    </data>
</odoo>